---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
---

<Layout title="Coules Labs — AI-Native Software Development">
	<header>
		<nav>
			<div class="logo">
				<img src="/images/logo-transparent.png" alt="Coules Labs" width="40" height="40" />
				<span class="logo-text">Coules Labs</span>
			</div>
			<div class="nav-right">
				<a href="#services">Services</a>
				<a href="#about">About</a>
				<a href="#contact">Contact</a>
				<ThemeToggle />
			</div>
		</nav>
	</header>

	<main>
		<!-- Hero -->
		<section class="hero">
			<div class="container">
				<img src="/images/logo-transparent.png" alt="Coules Labs" class="hero-logo" width="120" height="120" />
				<h1>Coules Labs</h1>
				<p class="tagline">AI-native software development</p>
				<p class="subtitle">
					We build software with AI at the core — from hands-on development and systems modernization
					to helping organizations unlock the full potential of AI-augmented engineering.
				</p>
				<div class="cta-group">
					<a href="#contact" class="btn btn-primary">Get in Touch</a>
					<a href="#services" class="btn btn-secondary">Learn More</a>
				</div>
			</div>
		</section>

		<!-- Services -->
		<section id="services" class="services">
			<div class="container">
				<h2>What We Do</h2>
				<div class="card-grid">
					<div class="card">
						<div class="card-icon">{ }</div>
						<h3>Custom Development</h3>
						<p>
							Full-stack software development leveraging AI-augmented workflows.
							From greenfield applications to modernizing complex legacy systems,
							we deliver production-grade code with the speed and quality that
							AI-native development enables.
						</p>
					</div>
					<div class="card">
						<div class="card-icon">&lt;/&gt;</div>
						<h3>AI Enablement</h3>
						<p>
							Help your engineering teams adopt AI coding tools effectively.
							We bring hands-on experience coordinating Claude Code, Codex,
							Gemini, and Cursor on real-world projects — not just demos —
							with proven practices for quality, security, and maintainability.
						</p>
					</div>
					<div class="card">
						<div class="card-icon">&#9670;</div>
						<h3>Product Development</h3>
						<p>
							Building our own AI-native products. From concept to launch,
							we're applying everything we know about platform architecture,
							developer experience, and AI-augmented engineering to create
							tools that matter.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- About -->
		<section id="about" class="about">
			<div class="container">
				<h2>About</h2>
				<div class="about-content">
					<p>
						Coules Labs is led by <strong>Jake Savin</strong>, a technical leader with
						20+ years of experience shipping software at scale. From building products
						used by hundreds of millions at Microsoft and Amazon to pioneering blogging
						infrastructure in the early web, Jake brings deep expertise in platform
						architecture, distributed systems, and cross-functional delivery.
					</p>
					<p>
						Most recently, Jake led AI/ML personalization and voice platform programs at
						Amazon Music — including their first GenAI-powered product — and managed
						complex technical partnerships with Apple and Google. He holds a patent in
						UI virtualization and is an active member of the RSS Advisory Board.
					</p>
					<p>
						Now, through Coules Labs, Jake is focused on what's next: building software
						the AI-native way and helping others do the same. Based in Seattle.
					</p>
					<div class="credentials">
						<span class="credential">Ex-Amazon</span>
						<span class="credential">Ex-Microsoft</span>
						<span class="credential">Patent Holder</span>
						<span class="credential">RSS Advisory Board</span>
						<span class="credential">Reed College</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Contact -->
		<section id="contact" class="contact">
			<div class="container">
				<h2>Get in Touch</h2>
				<p class="contact-text">
					Interested in working together? Whether you need development help,
					want to bring AI-native practices to your team, or just want to connect —
					we'd love to hear from you.
				</p>
				<div class="contact-links">
					<a href="mailto:jake@couleslabs.com" class="btn btn-primary">jake@couleslabs.com</a>
					<a href="https://www.linkedin.com/in/jakesavin" target="_blank" rel="noopener" class="btn btn-secondary">LinkedIn</a>
					<a href="https://github.com/coules-labs" target="_blank" rel="noopener" class="btn btn-secondary">GitHub</a>
				</div>
			</div>
		</section>
	</main>

	<footer>
		<div class="container">
			<p>&copy; 2026 Coules Labs LLC. All rights reserved.</p>
		</div>
	</footer>
</Layout>

<style>
	/* Header & Nav */
	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: var(--color-bg);
		border-bottom: 1px solid var(--color-border);
		backdrop-filter: blur(12px);
		background: color-mix(in srgb, var(--color-bg) 85%, transparent);
	}

	nav {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0.75rem 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}

	.logo img {
		border-radius: 6px;
	}

	.logo-text {
		font-weight: 600;
		font-size: 1.1rem;
		color: var(--color-text);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.nav-right a {
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--color-text-secondary);
		transition: color 0.2s ease;
	}

	.nav-right a:hover {
		color: var(--color-accent);
	}

	/* Container */
	.container {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	/* Hero */
	.hero {
		padding: 10rem 0 6rem;
		text-align: center;
	}

	.hero-logo {
		margin-bottom: 1.5rem;
		border-radius: 16px;
	}

	h1 {
		font-size: 3rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		letter-spacing: -0.02em;
	}

	.tagline {
		font-size: 1.25rem;
		color: var(--color-accent);
		font-weight: 500;
		margin-bottom: 1.5rem;
	}

	.subtitle {
		font-size: 1.1rem;
		color: var(--color-text-secondary);
		max-width: 640px;
		margin: 0 auto 2.5rem;
		line-height: 1.7;
	}

	.cta-group {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	/* Buttons */
	.btn {
		display: inline-block;
		padding: 0.75rem 1.75rem;
		border-radius: 8px;
		font-weight: 500;
		font-size: 0.95rem;
		transition: all 0.2s ease;
	}

	.btn-primary {
		background: var(--color-accent);
		color: #fff;
	}

	.btn-primary:hover {
		background: var(--color-accent-light);
		color: #fff;
	}

	.btn-secondary {
		border: 1px solid var(--color-border);
		color: var(--color-text);
	}

	.btn-secondary:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	/* Services */
	.services {
		padding: 5rem 0;
		background: var(--color-bg-secondary);
	}

	h2 {
		font-size: 2rem;
		font-weight: 700;
		text-align: center;
		margin-bottom: 3rem;
		letter-spacing: -0.01em;
	}

	.card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 1.5rem;
	}

	.card {
		background: var(--color-card-bg);
		border: 1px solid var(--color-border);
		border-radius: 12px;
		padding: 2rem;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.card:hover {
		border-color: var(--color-accent);
		box-shadow: 0 4px 20px var(--color-card-shadow);
	}

	.card-icon {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--color-accent);
		margin-bottom: 1rem;
		font-family: 'Courier New', monospace;
	}

	.card h3 {
		font-size: 1.2rem;
		font-weight: 600;
		margin-bottom: 0.75rem;
	}

	.card p {
		color: var(--color-text-secondary);
		line-height: 1.7;
		font-size: 0.95rem;
	}

	/* About */
	.about {
		padding: 5rem 0;
	}

	.about-content {
		max-width: 720px;
		margin: 0 auto;
	}

	.about-content p {
		color: var(--color-text-secondary);
		line-height: 1.8;
		margin-bottom: 1.25rem;
		font-size: 1rem;
	}

	.about-content strong {
		color: var(--color-text);
	}

	.credentials {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.credential {
		padding: 0.4rem 1rem;
		border: 1px solid var(--color-border);
		border-radius: 20px;
		font-size: 0.85rem;
		color: var(--color-text-secondary);
		font-weight: 500;
	}

	/* Contact */
	.contact {
		padding: 5rem 0;
		background: var(--color-bg-secondary);
		text-align: center;
	}

	.contact-text {
		color: var(--color-text-secondary);
		max-width: 560px;
		margin: 0 auto 2rem;
		line-height: 1.7;
		font-size: 1.05rem;
	}

	.contact-links {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	/* Footer */
	footer {
		padding: 2rem 0;
		text-align: center;
		border-top: 1px solid var(--color-border);
	}

	footer p {
		color: var(--color-text-secondary);
		font-size: 0.85rem;
	}

	/* Responsive */
	@media (max-width: 768px) {
		h1 {
			font-size: 2.25rem;
		}

		.hero {
			padding: 8rem 0 4rem;
		}

		.nav-right a {
			display: none;
		}

		.card-grid {
			grid-template-columns: 1fr;
		}

		.services, .about, .contact {
			padding: 3.5rem 0;
		}
	}
</style>
