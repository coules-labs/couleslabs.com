---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
---

<Layout title="Coules Labs — AI-Native Software Development">
	<header>
		<nav>
			<a href="/" class="logo">
				<img src="/images/logo-transparent.png" alt="Coules Labs" width="40" height="40" />
				<span class="logo-text">Coules Labs</span>
			</a>
			<div class="nav-right">
				<a href="#services">Services</a>
				<a href="#about">About</a>
				<a href="#contact">Contact</a>
				<ThemeToggle />
			</div>
		</nav>
	</header>

	<main>
		<!-- Hero -->
		<section class="hero">
			<div class="container">
				<img src="/images/logo-transparent.png" alt="Coules Labs" class="hero-logo" width="120" height="120" />
				<h1>Coules Labs</h1>
				<p class="tagline">AI-Native software development</p>
				<p class="subtitle">
					We build software with AI at the core:<br/>Hands-on development, systems modernization,
					and helping organizations unlock the potential of AI-augmented engineering.
				</p>
				<div class="cta-group">
					<a href="#contact" class="btn btn-primary">Get in Touch</a>
					<a href="#services" class="btn btn-secondary">Learn More</a>
				</div>
			</div>
		</section>

		<!-- Services -->
		<section id="services" class="services">
			<div class="container">
				<h2>What We Do</h2>
				<div class="card-grid">
					<div class="card">
						<div class="card-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<!-- Hammer -->
								<path d="M15 12l-8.5 8.5c-.83.83-2.17.83-3 0 0 0 0 0 0 0a2.12 2.12 0 0 1 0-3L12 9" />
								<path d="M17.64 15L22 10.64" />
								<path d="M20.91 11.7l-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91" />
							</svg>
							<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<!-- Terminal -->
								<polyline points="4 17 10 11 4 5"></polyline>
								<line x1="12" y1="19" x2="20" y2="19"></line>
							</svg>
						</div>
						<h3>Custom Development</h3>
						<p>
							Full-stack software development leveraging AI-augmented workflows.
							From greenfield applications to modernizing complex legacy systems,
							we deliver production-grade code with the speed and quality that
							AI-Native development enables.
						</p>
					</div>
					<div class="card">
						<div class="card-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<!-- Lightbulb -->
								<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" />
								<path d="M9 18h6" />
								<path d="M10 22h4" />
							</svg>
							<svg xmlns="http://www.w3.org/2000/svg" width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<!-- Sparkles -->
								<path d="M12 3l1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5L12 3z" />
								<path d="M19 13l.75 2.25L22 16l-2.25.75L19 19l-.75-2.25L16 16l2.25-.75L19 13z" />
							</svg>
						</div>
						<h3>AI Enablement</h3>
						<p>
							Help your engineering teams adopt AI coding tools effectively.
							We bring hands-on experience coordinating Claude Code, Codex,
							Gemini, and Cursor on real-world projects — not just demos —
							with proven practices for quality, security, and maintainability.
						</p>
					</div>
					<div class="card">
						<div class="card-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<!-- Rocket -->
								<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" />
								<path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />
								<path d="M9 12H4s.55-3.03 2-4c1.62-1.08 3 0 3 0" />
								<path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-3 0-3" />
							</svg>
							<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<!-- Compass -->
								<circle cx="12" cy="12" r="10"></circle>
								<circle cx="12" cy="12" r="1"></circle>
								<!-- Needle north (filled) -->
								<polygon points="12 7 13 10.5 12 12 11 10.5" fill="currentColor" stroke="currentColor" />
								<!-- Needle south (outline only) -->
								<polygon points="12 17 13 13.5 12 12 11 13.5" fill="none" stroke-width="0.75" />
								<!-- Cardinal ticks -->
								<line x1="12" y1="2" x2="12" y2="4" />
								<line x1="12" y1="20" x2="12" y2="22" />
								<line x1="2" y1="12" x2="4" y2="12" />
								<line x1="20" y1="12" x2="22" y2="12" />
							</svg>
						</div>
						<h3>Product Development</h3>
						<p>
							Building our own AI-Native products. From concept to launch,
							we're applying everything we know about platform architecture,
							developer experience, and AI-augmented engineering to create
							tools that matter.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- About -->
		<section id="about" class="about">
			<div class="container">
				<h2>About</h2>
				<div class="about-content">
					<p>
						Coules Labs is a Seattle-based software studio founded by
						<strong>Jake Savin</strong>, a veteran technical leader who has
						shipped products to hundreds of millions of users
						with companies like Amazon, Microsoft, Sony, SlingTV,
						ESPN, Starbucks, The New York Times, and NPR. We build software the AI-Native way
						and help engineering organizations do the same.
					</p>
					<p>
						Our work is grounded in three decades of shipping products at scale:
						platform architecture, distributed systems, GenAI,
						cross-functional delivery, and strategic technical partnerships.
					</p>
				</div>
			</div>
		</section>

		<!-- Contact -->
		<section id="contact" class="contact">
			<div class="container">
				<h2>Get in Touch</h2>
				<p class="contact-text">
					Interested in working together? Whether you need development help,
					want to bring AI-Native practices to your team, or just want to connect —
					we'd love to hear from you!
				</p>
				<div class="contact-links">
					<a href="mailto:info@couleslabs.com?subject=Let's%20work%20together" class="btn btn-primary">info@couleslabs.com</a>
				</div>
			</div>
		</section>
	</main>

	<footer>
		<div class="container">
			<p>&copy; 2026 Coules Labs LLC. All rights reserved.</p>
		</div>
	</footer>
</Layout>

<style>
	/* Header & Nav */
	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: var(--color-bg);
		border-bottom: 1px solid var(--color-border);
		backdrop-filter: blur(12px);
		background: color-mix(in srgb, var(--color-bg) 85%, transparent);
	}

	nav {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0.75rem 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		text-decoration: none;
		color: inherit;
	}

	.logo:hover {
		color: inherit;
	}

	.logo img {
		border-radius: 6px;
	}

	.logo-text {
		font-weight: 600;
		font-size: 1.1rem;
		color: var(--color-text);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.nav-right a {
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--color-text-secondary);
		transition: color 0.2s ease;
	}

	.nav-right a:hover {
		color: var(--color-accent);
	}

	/* Container */
	.container {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	/* Hero */
	.hero {
		padding: 10rem 0 6rem;
		text-align: center;
	}

	.hero-logo {
		margin-bottom: 1.5rem;
		border-radius: 16px;
	}

	h1 {
		font-size: 3rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		letter-spacing: -0.02em;
	}

	.tagline {
		font-size: 1.25rem;
		color: var(--color-accent);
		font-weight: 500;
		margin-bottom: 1.5rem;
	}

	.subtitle {
		font-size: 1.1rem;
		color: var(--color-text-secondary);
		max-width: 560px;
		margin: 0 auto 2.5rem;
		line-height: 1.7;
	}

	.cta-group {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	/* Buttons */
	.btn {
		display: inline-block;
		padding: 0.75rem 1.75rem;
		border-radius: 8px;
		font-weight: 500;
		font-size: 0.95rem;
		transition: all 0.2s ease;
	}

	.btn-primary {
		background: var(--color-accent);
		color: #fff;
	}

	.btn-primary:hover {
		background: var(--color-accent-light);
		color: #fff;
	}

	.btn-secondary {
		border: 1px solid var(--color-border);
		color: var(--color-text);
	}

	.btn-secondary:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	/* Services */
	.services {
		padding: 5rem 0;
		background: var(--color-bg-secondary);
	}

	h2 {
		font-size: 2rem;
		font-weight: 700;
		text-align: center;
		margin-bottom: 3rem;
		letter-spacing: -0.01em;
	}

	.card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 1.5rem;
	}

	.card {
		background: var(--color-card-bg);
		border: 1px solid var(--color-border);
		border-radius: 12px;
		padding: 2rem;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.card:hover {
		border-color: var(--color-accent);
		box-shadow: 0 4px 20px var(--color-card-shadow);
	}

	.card-icon {
		color: var(--color-accent);
		margin-bottom: 1rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.card h3 {
		font-size: 1.2rem;
		font-weight: 600;
		margin-bottom: 0.75rem;
	}

	.card p {
		color: var(--color-text-secondary);
		line-height: 1.7;
		font-size: 0.95rem;
	}

	/* About */
	.about {
		padding: 5rem 0;
	}

	.about-content {
		max-width: 720px;
		margin: 0 auto;
	}

	.about-content p {
		color: var(--color-text-secondary);
		line-height: 1.8;
		margin-bottom: 1.25rem;
		font-size: 1rem;
	}

	.about-content strong {
		color: var(--color-text);
	}

	.credentials {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.credential {
		padding: 0.4rem 1rem;
		border: 1px solid var(--color-border);
		border-radius: 20px;
		font-size: 0.85rem;
		color: var(--color-text-secondary);
		font-weight: 500;
	}

	/* Contact */
	.contact {
		padding: 5rem 0;
		background: var(--color-bg-secondary);
		text-align: center;
	}

	.contact-text {
		color: var(--color-text-secondary);
		max-width: 560px;
		margin: 0 auto 2rem;
		line-height: 1.7;
		font-size: 1.05rem;
	}

	.contact-links {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	/* Footer */
	footer {
		padding: 2rem 0;
		text-align: center;
		border-top: 1px solid var(--color-border);
	}

	footer p {
		color: var(--color-text-secondary);
		font-size: 0.85rem;
	}

	/* Responsive */
	@media (max-width: 768px) {
		h1 {
			font-size: 2.25rem;
		}

		.hero {
			padding: 8rem 0 4rem;
		}

		.nav-right a {
			display: none;
		}

		.card-grid {
			grid-template-columns: 1fr;
		}

		.services, .about, .contact {
			padding: 3.5rem 0;
		}
	}
</style>
